{
    "languageserver":{
        "go":{
            "command":"gopls",
            "rootPatterns":[
                "go.mod"
            ],
            "trace.server":"verbose",
            "filetypes":[
                "go"
            ]
        },
        "ccls": {
            "command": "ccls",
            "filetypes": ["c", "cpp", "objc", "objcpp"],
            "rootPatterns": [".ccls", "compile_commands.json", ".vim/", ".git/", ".hg/"],
            "initializationOptions": {
                "cache": {
                    "directory": "/tmp/ccls"
                },
                "clang": {
                    "extraArgs": [
                        "-std=c++17",
                        "-isystem",
                        "/usr/local/include"
                    ]
                }
            }
        },
        "pyls": {
            "command": "pyls",
            "filetypes": ["python"],
            "settings": {}
        }
    },
    "ccls.codeLens.enabled": true,

    "tsserver.implicitProjectConfig.experimentalDecorators": true,

    "imselect.defaultInput": "com.apple.keylayout.ABC",
    "imselect.enableStatusItem": true,

    "codeLens.enable": true,

    "signature.enable": true,

    "coc.preferences.enableFloatHighlight": true,
    "coc.preferences.enableMessageDialog": true,
    "coc.preferences.floatActions": true,
    "coc.preferences.currentFunctionSymbolAutoUpdate": true,

    "diagnostic.enableMessage": "always",
    "diagnostic.enableHighlightLineNumber": true,
    "diagnostic.enableSign": true,
    "diagnostic.errorSign": "✖",
    "diagnostic.warningSign": "⚠",
    "diagnostic.infoSign": "ℹ",
    "diagnostic.hintSign": "➤",

    "snippets.ultisnips.enable": true,
    "snippets.loadFromExtensions": true,
    "snippets.userSnippetsDirectory": "~/dotfiles/nvim/snippets",
    "snippets.autoTrigger": true,
    "snippets.priority": 200,

    "suggest.snippetIndicator": "~",
    "suggest.snippetsSupport": true,
    "suggest.defaultSortMethod": "alphabetical",
    "suggest.detailMaxLength": 100,
    "suggest.labelMaxLength": 80,
    "suggest.detailField": "preview",
    "suggest.disableKind": false,
    "suggest.autoTrigger": "trigger",
    "suggest.highPrioritySourceLimit": 20,
    "suggest.removeDuplicateItems": true,
    "suggest.floatEnable": true,
    "suggest.enablePreview": true,
    "suggest.disableMenu": false,
    "suggest.disableMenuShortcut": false,
    "suggest.minTriggerInputLength": 0,
    "suggest.acceptSuggestionOnCommitCharacter": false,
    "suggest.enablePreselect": true,
    "suggest.noselect": true,
    "suggest.echodocSupport": false,
    "suggest.preferCompleteThanJumpPlaceholder": false,

    "suggest.invalidInsertCharacters": [
        " ",
        "(",
        "<",
        "{",
        "[",
        ";",
        "\r",
        "\n"
    ],

    "suggest.completionItemKindLabels": {
        "keyword": "[key]",
        "variable": "[var]",
        "value": "[val]",
        "operator": "[op]",
        "constructor": "[new]",
        "function": "[func]",
        "reference": "[ref]",
        "constant": "[cons]",
        "method": "[me]",
        "struct": "[st]",
        "class": "[cls]",
        "text": "[txt]",
        "enum": "[enum]",
        "enumMember": "[emem]",
        "module": "[modl]",
        "color": "[colr]",
        "property": "[prop]",
        "field": "[fild]",
        "unit": "[unit]",
        "event": "[evnt]",
        "file": "[file]",
        "folder": "[dir]",
        "snippet": "[snip]",
        "typeParameter": "[tparam]",
        "default": "[none]"
    }
}
