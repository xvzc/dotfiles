{
    "languageserver":{
        "go":{
            "command":"gopls",
            "rootPatterns":[
                "go.mod"
            ],
            "trace.server":"verbose",
            "filetypes":[
                "go"
            ]
        },

        "ccls": {
            "command": "ccls",
            "filetypes": ["c", "cpp", "objc", "objcpp"],
            "rootPatterns": [".ccls", "compile_commands.json", ".vim/", ".git/", ".hg/"],
            "initializationOptions": {
                "cache": {
                    "directory": "/tmp/ccls"
                },
                "clang": {
                    "extraArgs": [
                        "-std=c++17",
                        "-isystem",
                        "/usr/local/include"
                    ]
                }
            }
        },
        "pyls": {
            "command": "pyls",
            "filetypes": ["python"],
            "settings": {}
        }
    },
    "imselect.defaultInput": "com.apple.keylayout.ABC",
    "imselect.enableStatusItem": true,
    "snippets.priority": 200,

    "diagnostic.enableMessage": "never",
    "diagnostic.virtualTextLines": 5,
    "diagnostic.enableHighlightLineNumber": true,
    "diagnostic.virtualText": true,
    "diagnostic.virtualTextPrefix": "    |  ",
    "diagnostic.enableSign": true,
    "snippets.ultisnips.enable": true,
    "snippets.loadFromExtensions": true,

    "diagnostic.errorSign": "✖",
    "diagnostic.warningSign": "⚠",
    "diagnostic.infoSign": "ℹ",
    "diagnostic.hintSign": "➤",

    "codeLens.enable": false,
    "signature.enable": false,

    "tsserver.implicitProjectConfig.experimentalDecorators": true,

    "suggest.snippetIndicator": "~",

    "suggest.defaultSortMethod": "alphabetical",

    "suggest.detailMaxLength": 100,
    "suggest.detailField": "preview",
    "suggest.disableKind": false,

    "suggest.removeDuplicateItems": true,
    "suggest.floatEnable": true,
    "suggest.enablePreview": true,
    "suggest.disableMenu": false,
    "suggest.disableMenuShortcut": false,

    "suggest.noselect": false,
    "suggest.echodocSupport": false,
    "suggest.preferCompleteThanJumpPlaceholder": false,
    "suggest.completionItemKindLabels": {
        "keyword": "\uf1de",
        "variable": "\ue79b",
        "value": "\uf89f",
        "operator": "\u03a8",
        "constructor": "\uf0ad",
        "function": "\u0192",
        "reference": "\ufa46",
        "constant": "\uf8fe",
        "method": "\uf09a",
        "struct": "\ufb44",
        "class": "\uf0e8",
        "text": "\ue612",
        "enum": "\uf435",
        "enumMember": "\uf02b",
        "module": "\uf40d",
        "color": "\ue22b",
        "property": "\ue624",
        "field": "\uf9be",
        "unit": "\uf475",
        "event": "\ufacd",
        "file": "\uf723",
        "folder": "\uf114",
        "snippet": "\ue60b",
        "typeParameter": "\uf728",
        "default": "\uf29c"
    }
}
